{
    "displayResponseTimes": true,
    "LLM_PROVIDER": "zai",
    "orchestrator_mode": "langchain",
    "postcheck": {
        "enabled": false,
        "log_verdicts": false,
        "judge": {
            "enabled": true,
            "provider": "zai",
            "model": "glm-4.5-air"
        },
        "react_fallback": {
            "enabled": false,
            "max_iterations": 4
        }
    },
    "reactAgent": {
        "max_iterations": 5
    },
    "domainClassifier": {
        "provider": "zai",
        "model": "glm-4.5-air"
    },
    "routingAndKeywords": {
        "provider": "zai",
        "model": "glm-4.5-air"
    },
    "embeddings": {
        "provider": "openai_compatible",
        "model": "doubao-embedding-vision",
        "base_url": "https://ark.cn-beijing.volces.com/api/coding/v3",
        "api_key": "YOUR_ARK_EMBEDDING_API_KEY_HERE"
    },
    "localRag": {
        "chunk_size": 1000,
        "chunk_overlap": 200
    },
    "YOU_API_KEY": "YOUR_YOU_API_KEY_HERE",
    "GOOGLE_API_KEY": "YOUR_GOOGLE_API_KEY_HERE",
    "GOOGLE_CX": "YOUR_GOOGLE_CUSTOM_SEARCH_ENGINE_ID_HERE",
    "brightDataSearch": {
        "api_token": "YOUR_BRIGHTDATA_API_TOKEN_HERE",
        "zone": "serp_api1",
        "base_url": "https://api.brightdata.com/request",
        "timeout": 20,
        "search_url_template": "https://www.google.com/search?q={query}"
    },
    "braveSearch": {
        "primary_api_key": "YOUR_BRAVE_PRIMARY_API_KEY_HERE",
        "secondary_api_key": "YOUR_BRAVE_SECONDARY_API_KEY_HERE",
        "base_url": "https://api.search.brave.com/res/v1/web/search",
        "timeout": 15,
        "rps": 1,
        "monthly_limit": 2000,
        "usage_log_path": "runtime/brave_search_usage.jsonl"
    },
    "FINNHUB_API_KEY": "",
    "APISPORTS_KEY": "",
    "RAPIDAPI_KEY": "",
    "youSearch": {
        "country": "US",
        "safesearch": "moderate",
        "include_news": true,
        "default_count": 8
    },
    "googleSearch": {
        "lr": "lang_zh-CN|lang_zh-TW|lang_en",
        "safe": "medium",
        "timeout": 15
    },

    "rerank": {
        "enabled": true,
        "api_key": "YOUR_DASHSCOPE_API_KEY_HERE",
        "model": "qwen3-rerank",
        "min_score": 0.0,
        "max_per_domain": 1,
        "providers": {
            "qwen": {
                "api_key": "YOUR_DASHSCOPE_API_KEY_HERE",
                "model": "qwen3-rerank",
                "base_url": "https://dashscope.aliyuncs.com/api/v1/services/rerank",
                "timeout": 15
            }
        }
    },
    "providers": {
        "openai": {
            "api_key": "YOUR_OPENAI_API_KEY_HERE",
            "model": "gpt-3.5-turbo",
            "base_url": "https://api.openai.com/v1"
        },
        "google": {
            "api_key": "YOUR_GOOGLE_API_KEY_HERE",
            "model": "gemini-pro",
            "base_url": "https://generativelanguage.googleapis.com/v1beta"
        },
        "hkgai": {
            "api_key": "YOUR_HKGAI_API_KEY_HERE",
            "model": "HKGAI-V1",
            "base_url": "https://oneapi.hkgai.net/v1"
        },
        "zai": {
            "api_key": "YOUR_ZAI_API_KEY_HERE",
            "model": "glm-4.6",
            "base_url": "https://open.bigmodel.cn/api/anthropic",
            "available_models": [
                "glm-4.6",
                "glm-4.5-air"
            ]
        },
        "openrouter": {
            "api_key": "YOUR_OPENROUTER_API_KEY_HERE",
            "model": "minimax/minimax-m2:free",
            "base_url": "https://openrouter.ai/api/v1",
            "available_models": [
                "minimax/minimax-m2:free",
                "x-ai/grok-4.1-fast:free",
                "deepseek/deepseek-r1-0528:free"
            ]
        },
        "minimax": {
            "api_key": "YOUR_MINIMAX_API_KEY_HERE",
            "model": "MiniMax-M2",
            "base_url": "https://api.minimaxi.com/anthropic/v1",
            "thinking": {
                "enabled": true,
                "display_in_response": false
            },
            "available_models": [
                "MiniMax-M2"
            ]
        }
    }
}
